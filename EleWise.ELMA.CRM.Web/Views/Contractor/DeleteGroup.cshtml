@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA
@model GroupContractorInfo
<div style="padding: 5px">
    @using (Html.ELMAForm("Delete", "Contractor", new { area = CRMAreaRegistration.AREA_NAME }))
    {
        for (int i = 0; i <= Model.Contractors.Count - 1; i++)
        {
            @Html.HiddenFor(m => m.Contractors[i].Id)
        }
        <div class="form-label">
            @(Model.Contractors.Count > 1 ? SR.T("Удалить выбранных контрагентов?") : SR.T("Удалить выбранного контрагента?"))
        </div>
        <div class="popup-buttons">
            <input type="submit" class="confirm" value="@SR.T("Удалить")" />
            <input type="button" value="@SR.Cancel" onclick="@Html.ClosePopup(Model.PopupId)" />
        </div>
    }
</div>
