@(Html.Toolbar().Group("toolbar-group-1")
            .If(canAdd, b => b.ToolbarButton(allContractorsAvailable ? new ActionToolbarItem("toolbar-button-Add")
                {
                    IsMainAction = true,
                    Text = SR.T("Создать"),
                    IconUrl = "#add.svg",
                    Items = new ActionItemList(Locator.GetServiceNotNull<IMetadataRuntimeService>()
                        .GetMetadataList()
                        .Where(m => m is ClassMetadata && (((ClassMetadata)m).BaseClassUid.ToString() == availableUid) && m is EntityMetadata &&( service.HasPermission(CRMPermissionProvider.GetCreateContractorPermission(((EntityMetadata)m).ImplementationUid)) || service.HasPermission(CRMPermissionProvider.CRMFullAccessPermission)))
                        .Cast<ClassMetadata>()
                        .Select(md => (IActionItem)new ActionToolbarItem("Contractors_add_" + md.Name + "_btn")
                        {
                            Text = SR.T(md.DisplayName),
                            IconUrl = Url.Action("Object", "Images", new { area = SDKRouteProvider.AreaName, id = md.Uid, size = ObjectIconFormat.x16 }),
                            Url = Url.EntityAction<ContractorCreateAttribute>(md.Uid)
                        })
                        .Where(i => ((ActionToolbarItem)i).Url != "/CRM")
                        .OrderBy(i => ((ActionToolbarItem)i).Text)
                        .ToArray())
                } : new ActionToolbarItem("toolbar-action-AddContractor")
                {
                    Text = SR.Add,
                    IconUrl = "#add.svg",
                    Url = Url.EntityAction<ContractorCreateAttribute>(classMetadata.Uid),
                    ToolTip = string.Format(SR.T("Добавить {0}"), SR.T(classMetadata.DisplayName))
                }))
            .ToolbarButton(new ActionToolbarItem("toolbar-button-SelectedActions")
                {
                    Text = SR.T("Выбранные"),
                    IconUrl = "#select_all.svg",
                    Items = new ActionItemList{
                    new ActionToolbarItem("Contractors_add_call")
                        {
                            Text = SR.T("Добавить"), IconUrl = "#add.svg",
                            Items = new ActionItemList {
                                new ActionToolbarItem("Contractors_add_call_btn")
                                {
                                    Text = SR.T("Звонки"), IconUrl = "#add.svg",
                                    Click = "AddCalls();"
                                },
                                new ActionToolbarItem("Contractors_add_meeting_btn")
                                {
                                    Text = SR.T("Встречи"), IconUrl = "#add_meeting.svg", Click = "AddMeetings();"
                                },
                                new ActionToolbarItem("Contractors_add_mail_btn")
                                {
