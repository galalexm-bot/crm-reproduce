@Html.FilterEditButton(new EleWise.ELMA.BPM.Web.Common.Models.FilterEditButtonModel
{
    FilterId = Convert.ToInt64(Request["FilterId"]),
    Area = RouteProvider.AreaName,
    ControllerName = "Contractor",
    BackUrl = Request.RawUrl
}) 


@Html.PopupWindow("PopUpDeleteContractors", SR.T("Подтверждение удаления"), @<text></text>, width: 400)
@Html.PopupWindow("MarketingActivitySelectionPopup", SR.T("Выберите маркетинговое мероприятие"), @<text></text>)
@Html.ExtensionZone("EleWise.ELMA.CRM.Workflow.Processes.Web.StartProcessContractors")

<script type="text/javascript">

    function SetMarketingActivity()
    {
        var url = '@Url.Action("AssignActivityToManyEntities", "MarketingActivity", new { area = CRMAreaRegistration.AREA_NAME })?';
        var noSelectedEntitiesMsg = '@(SR.T("Нет выбранных контрагентов"))';
        var entityName = '@System.Web.HttpUtility.UrlEncode(SR.T("контрагентам"))';
        var entitiesNameForErrorMessage = '@System.Web.HttpUtility.UrlEncode(SR.T("контрагентов"))';
        AssignMarketingActivity(url, '@typeUid', noSelectedEntitiesMsg, 'Index', 'Contractor', entityName, entitiesNameForErrorMessage);   
    }

    function DeleteContractors()
    {
        var selectedContractors = GetSelectedObjects();
        if (selectedContractors.length == 0) {
            jAlert('@(SR.T("Нет выбранных контрагентов"))', '@(SR.T("Предупреждение"))');
            return;
        }
        var url = '@Url.Action("Delete", "Contractor", new { area = CRMAreaRegistration.AREA_NAME, popupId = "PopUpDeleteContractors" })';
        if (selectedContractors.length > 0)
        {
            $.each(selectedContractors, function(i, d) {
                url += '&contractorsId=' + d;
            });
            var window = $('#PopUpDeleteContractors').data("tWindow");
            window.contentUrl = url;
            window.loaded = false;
            @(Html.OpenPopup("PopUpDeleteContractors"))
        }
    }

    function AddCalls()
    {
        var selectedContractors = GetSelectedObjects();
        if (selectedContractors.length == 0) {
            jAlert('@(SR.T("Нет выбранных контрагентов"))', '@(SR.T("Предупреждение"))');
            return;
        }
        
        if (selectedContractors.length > 0)
        {
            var url = '@Url.Action("CreateMany", "RelationshipCall", new { area = CRMAreaRegistration.AREA_NAME })';
            url += "?";
            $.each(selectedContractors, function(i, d) {
                url += '&contractorsId=' + d;
            });
            window.replaceUrl(url);
        }
    }
        
    function AddMeetings()
    {
        var selectedContractors = GetSelectedObjects();
        if (selectedContractors.length == 0) {
            jAlert('@(SR.T("Нет выбранных контрагентов"))', '@(SR.T("Предупреждение"))');
            return;
        }
        
        if (selectedContractors.length > 0)
        {
            var url = '@Url.Action("CreateMany", "RelationshipMeeting", new { area = CRMAreaRegistration.AREA_NAME })';
            url += "?";
            $.each(selectedContractors, function(i, d) {
                url += '&contractorsId=' + d;
            });
            window.replaceUrl(url);
        }
    }
    
    function AddMails()
    {
        var selectedContractors = GetSelectedObjects();
        if (selectedContractors.length == 0) {
            jAlert('@(SR.T("Нет выбранных контрагентов"))', '@(SR.T("Предупреждение"))');
            return;
        }
        
        if (selectedContractors.length > 0)
        {
            var url = '@Url.Action("CreateMany", "RelationshipMail", new { area = CRMAreaRegistration.AREA_NAME })';
            url += "?";
            $.each(selectedContractors, function(i, d) {
                url += '&contractorsId=' + d;
            });
            window.replaceUrl(url);
        }
    }
    
</script>
 
<script type="text/javascript" src="@Url.Content("~/Modules/EleWise.ELMA.CRM.Web/Scripts/MarketingActivityAssigner.js")"></script>

@Html.Partial("Grid")
@{
  //  classMetadata = Locator.GetServiceNotNull<IMetadataRuntimeService>().GetMetadataList().Where(m => m is ClassMetadata && (m.Uid.ToString() == availableUid)).Cast<ClassMetadata>().Single();
  
  var buttonInfo = new StartRouteButtonInfo
            {
                ObjectType = InterfaceActivator.UID<IContractor>(false),
                
                RelationType = RelationType.OneToMany,
                ImageUrl = "#play.svg",
                Caption = SR.T("Для запуска процесса введите название экземпляра процесса,<br/>выберите процесс и нажмите кнопку \"Отправить\" или Enter:"),
                PopupId = "StartProcessByRoutePopup",
                Name=SR.T("Запуск процесса")
            };

            var routeValues = new RouteValueDictionary {  
                { "area", EleWise.ELMA.Workflow.Web.WorkflowRouteProvider.AreaName },
                { "ObjectType", buttonInfo.ObjectType },
                { "RelationType", buttonInfo.RelationType },
                { "PopupId", buttonInfo.PopupId },                
                { "Caption", buttonInfo.Caption },        
                { "Name", buttonInfo.Name }

};


}
@(Html.PopupWindow(buttonInfo.PopupId, SR.T("Запустить процесс"), Url.Action("StartRouteForm", "WorkflowInstance", routeValues)))
<script>
    function StartProcess() {
        var selectedContractors = GetSelectedObjects();
        if (selectedContractors.length == 0) {
            jAlert('@(SR.T("Нет выбранных контрагентов"))', '@(SR.T("Предупреждение"))');
            return;
        }
        
        if (selectedContractors.length > 0) {
            var url = '@MvcHtmlString.Create(Url.Action("StartRouteForm", "WorkflowInstance", routeValues))';
            if (selectedContractors.length < 2)
                url += '&RelationType=@buttonInfo.RelationType';
            else
                url += '&RelationType=@RelationType.ManyToMany';

            var i = 0;
            $.each(selectedContractors, function (i, d) {
                url += '&objects[' + i + ']=' + d;
                i++;
            });

            refreshPopup('@buttonInfo.PopupId', url);
            //id, contentUrl, postData, title, onOpenScript, onCloseScript, useReferrer, closeOnClick, closeOnEsc
                                        
        }

    }
    

    

</script>