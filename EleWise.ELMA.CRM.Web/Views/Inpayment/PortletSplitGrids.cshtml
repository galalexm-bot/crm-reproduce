@{
    Html.RegisterContent("updateGridTotalContent", @<text>
<script type="text/javascript">
    function updateGridTotal(gridId) {
        var ajaxData = $('#' + gridId).data('tGrid').ajaxData;
        $('#' + gridId + '_total #TotalInPlanWithDate').html(ajaxData.TotalInPlanWithDate);
        $('#' + gridId + '_total #TotalInPlanWithOutDate').html(ajaxData.TotalInPlanWithOutDate);
        $('#' + gridId + '_total #TotalReceived').html(ajaxData.TotalReceived);
        $('#' + gridId + '_total #Total').html(ajaxData.Total);
    }
</script></text>);
}