@using EleWise.ELMA
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA.CRM.Web.Controllers
@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.Web.Mvc.Models.Panels
@model InpaymentPortletModel

@using (Html.CollapsiblePanel(new CollapsiblePanel(){
    Id = ViewData.TemplateInfo.GetFullHtmlFieldId(String.Format("OldInpaymentsGridPortletPanel_{0}", Model.InstanceId)),
    Header = SR.T("Ранее"),
    SaveState = true,
    Class = "separator-gray",
    Expanded = false,
    Url = Url.Action(InpaymentController.GetGridIds[0] + "Action", "Inpayment", new { area = CRMAreaRegistration.AREA_NAME, Model.FilterId, portletView = true, showOnlyMy = Model.ShowOnlyMy, instanceId = Model.InstanceId })
})) {}

