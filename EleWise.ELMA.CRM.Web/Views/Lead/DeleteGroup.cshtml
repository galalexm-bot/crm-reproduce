@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA
@model GroupLeadInfo
    @using (Html.ELMAForm("DeleteGroup", "Lead", new { area = CRMAreaRegistration.AREA_NAME }))
    {
        for (int i = 0; i <= Model.Leads.Count - 1; i++)
        {
            @Html.HiddenFor(m => m.Leads[i].Id)
        }
        <div class="form-label">
            @(Model.Leads.Count > 1 ? SR.T("Удалить выбранных потенциальных клиентов?") : SR.T("Удалить выбранного потенциального клиента?"))
        </div>
        <div class="popup-buttons">
            <input type="submit" class="confirm" value="@SR.T("Удалить")" />
            <input type="button" value="@SR.Cancel" onclick="@Html.ClosePopup(Model.PopupId)" />
        </div>
    }
