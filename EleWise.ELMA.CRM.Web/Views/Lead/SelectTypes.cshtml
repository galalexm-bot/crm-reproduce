@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA
@model LeadChangeTypeModel
@using (Html.ELMAForm())
{
    for (int i = 0; i <= Model.LeadsId.Length - 1; i++)
    {
        @Html.HiddenFor(m => m.LeadsId[i])
    }
    <div class="form-label">
        @Html.EditableProperty(m => m.Types)
    </div>
    <div class="popup-buttons">
        <input type="submit" class="confirm" value="@SR.T("Установить")" />
        <input type="button" value="@SR.Cancel" onclick="@Html.ClosePopup("LeadChangeType")" />
    </div>
}
