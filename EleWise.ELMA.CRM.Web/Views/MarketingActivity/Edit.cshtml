@model EleWise.ELMA.CRM.Web.Models.MarketingActivityModel
@using EleWise.ELMA
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA.Model.Metadata

@{
    var metadata = (EntityMetadata)MetadataLoader.LoadMetadata(Model.Entity.GetType());
    Html.Header(SR.T("{0} \"{1}\"", metadata.DisplayName, Model.Entity.Name));
}

@(Html.Toolbar()
    .Group("toolbar-group-1")
        .ToolbarSubmit(SR.Save, "#save.svg", "toolbar-action-Save")
        .ToolbarLink(SR.Cancel, "#close_outline.svg", "javascript:history.back(-1);", "toolbar-action-Cancel"))

@Html.Partial("Editors/MarketingActivityEdit")

