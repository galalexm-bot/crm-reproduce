@model GridData<ILead>
@using EleWise.ELMA
@using EleWise.ELMA.CRM.Models
@using EleWise.ELMA.CRM.Web
@{
    const string gridId = "MarketingActivityRelatedLeadsGrid";
    var tabId = (string) ViewData["TabId"];
}
@(Html.DynamicGrid(gridId, Model).Columns(c =>
{
    c.For(m => m.Name).Link(m => Url.Entity(m));
    c.For(m => m.Responsible);
    c.For(m => Html.Image("#basket.svg", "", new { @class="vertical-middle" }))
        .Width(30)
        .Link(m => String.Format("javascript:void(removeLead({0}))", m.Id))
        .NotSortable()
        .Order(int.MaxValue);
})
)
@if (!String.IsNullOrEmpty(tabId))
{
    <script type="text/javascript">
        $('#@gridId').bind("load dataBound", function() {
            $('#@tabId > a').html('@SR.T("Возможности")' + '<span class="counter">' + $('#@gridId').data('tGrid').total + '</span>');
        });
    </script>
}
<script type="text/javascript">
    function removeLead(id) {
        jConfirm('@(SR.T("Вы действительно хотите удалить возможность из маркетингового мероприятия?"))', '@(SR.T("Подтверждение удаления"))', function (r) {
            if (r) {
                $.ajax({
                    url: '@Url.Action("RemoveLead", "MarketingActivity", new { area = CRMAreaRegistration.AREA_NAME })/' + id,
                    type: 'POST',
                    success: function () {
                        refreshLeadsGird();
                    }
                });
            }
        });
    }
    function refreshLeadsGird() {
        $('#@gridId').data('tGrid').ajaxRequest();
    }    
</script>