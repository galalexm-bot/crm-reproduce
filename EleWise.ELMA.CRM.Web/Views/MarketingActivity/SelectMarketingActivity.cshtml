@using EleWise.ELMA.CRM.Types
@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.CRM.Web
@using EleWise.ELMA
@model SelectMarketingActivityModel
           
@using (Html.ELMAForm("AssignActivityToManyEntities", "MarketingActivity", new { area = CRMAreaRegistration.AREA_NAME }))
{
    for (int i = 0; i <= Model.EntitiesId.Length - 1; i++)
    {
        @Html.HiddenFor(m => m.EntitiesId[i])
    }
        
    @Html.HiddenFor(m => m.EntityTypeUid)
    @Html.HiddenFor(m => m.RedirectControllerName)
    @Html.HiddenFor(m => m.RedirectActionName)
    @Html.HiddenFor(m => m.EntitiesName)
    @Html.HiddenFor(m => m.EntitiesNameForErrorMessage)
        
    <div class="form-label">
        @Html.Editor(m => m.MarketingEffect, a => a.TypeSettings = new MarketingEffectSettings() {IsComposite = true})
    </div>
    <div class="popup-buttons">
        <input type="submit" class="confirm" value="@SR.T("Выбрать")" />
        <input type="button" value="@SR.Cancel" onclick="@Html.ClosePopup("MarketingActivitySelectionPopup")" />
    </div>
}

