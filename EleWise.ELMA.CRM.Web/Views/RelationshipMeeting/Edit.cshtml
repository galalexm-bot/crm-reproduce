@model EleWise.ELMA.CRM.Web.Models.RelationshipMeetingModel
@using EleWise.ELMA;
@using EleWise.ELMA.CRM.Web

@{
    Html.Header(SR.T("Назначить встречу"));
    var checkEventTimePeriod = ViewData.TemplateInfo.GetFullHtmlFieldId("checkEventTimePeriodMeeting");
}

@(Html.Toolbar()
    .Group("toolbar-group-1")
        .Button("toolbar-click-Save", b => b.Text(SR.Save).IconUrl("#save.svg").Click(checkEventTimePeriod + "('GlobalForm','');").MainAction())
        .ToolbarLink(SR.Cancel, "#close_outline.svg", "javascript:history.back(-1);", "toolbar-action-Cancel"))

@Html.Partial("Editors/RelationshipMeetingEdit")