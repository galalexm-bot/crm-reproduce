@using System.ComponentModel
@using EleWise.ELMA.BPM.Web.Common.Extensions
@using EleWise.ELMA.CRM.Models
@using EleWise.ELMA.BPM.Web.Common.Models
@model GridDataFilter<ISale>

@(Html.FilterDynamicGrid(Model)
    .Columns(c =>
    {
        c.For(m => m.Name).Link(m => Url.Action("Details", "Sale", new { id = m.Id }));
        c.For(m => m.SaleStage).Template(m => m.SaleStage != null ? MvcHtmlString.Create(m.SaleStage.Name) : MvcHtmlString.Empty);
        c.For(m => m.Contractor);
        if (Model.DataFilter == null || !((ISaleFilter)Model.DataFilter.Filter).ShowOnlyMy)
        {
            c.For(m => m.Responsible);
        }
    })
    .Action("PortletGrid").Customizable(false).DefaultSortExpression("SaleStage").DefaultSortDirection(ListSortDirection.Descending))
