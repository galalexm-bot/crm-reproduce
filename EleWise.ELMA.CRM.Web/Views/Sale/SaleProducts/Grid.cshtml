@using EleWise.ELMA
@using EleWise.ELMA.CRM.Models
@using EleWise.ELMA.Common.Models
@model GridData<ISaleProduct, ISaleProductFilter>
@{
    var readOnly = (bool) ViewData["ReadOnly"];
}
@(Html.DynamicGrid("SaleProductGrid1", Model).Columns(c =>
{
    c.For(m => m.Product.Name).Header(SR.T("Название"));
    c.For(m => m.Quantity).Header(SR.T("Количество")).Width(150);
    c.For(m => m.Product.Price)
        .Header(SR.T("Цена"))
        .Width(120)
        .NotSortable()
        .HtmlAttributes(new { style = "text-align: right" });
    c.For(m => Html.HtmlHelperFunc((Money) ((m.Product.Price ?? 0.00) * m.Quantity), helper => helper.Display(x => x, null)))
        .Header(SR.T("Стоимость"))
        .Width(120)
        .NotSortable()
        .HtmlAttributes(new { style = "text-align: right"});
    if (!readOnly)
    {
        c.For(m => m.Id)
            .Template(@<text>@Html.Button().IconUrl("#edit.svg").Circle().NoBorder().Click("editProduct(" + item.Id + ")")</text>)
            .Header(String.Empty)
            .Order(int.MaxValue)
            .NotSortable()
            .Width(30);
        c.For(m => m.Id)
            .Template(@<text>@Html.Button().IconUrl("#basket.svg").Circle().NoBorder().Click("onDeleteProductClick(" + item.Id + ")")</text>)
            .Header(String.Empty)
            .Order(int.MaxValue)
            .NotSortable()
            .Width(30);
    }
}).Action("ProductsGrid").Customizable(false))