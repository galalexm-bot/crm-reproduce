@using EleWise.ELMA;
@using EleWise.ELMA.BPM.Web.Common
@using EleWise.ELMA.CRM.Web.Controllers
           
@{
    var breadcrumbs = Html.Breadcrumbs("catalog-view")
        .Item(btn => btn.Text(SR.T("Справочники")).Url(Url.Action("Index", "Catalogs", new {
            area = CommonAreaRegistration.AREA_NAME
        })))
        // Корень
        .Item(btn => {
            btn.Text(SR.T("Воронки продаж"));
        });
    Html.Title(SR.T("Воронки продаж"));
    Html.RenderInZone("Header", d => breadcrumbs.ToHtmlString());

    Html.Toolbar()
        .IfHasPermission<EleWise.ELMA.CRM.Models.ISaleFunnel>(EleWise.ELMA.Security.Services.CommonPermissions.Create, g => g
            .Group("toolbar-group-1").ToolbarAction<SaleFunnelController>(a => a.Add(), SR.T("Создать"), "#add.svg", "toolbar-action-Add")
            .Group("toolbar-group-2").ToolbarAction<SaleStageController>(a => a.Index(), SR.T("Глобальный порядок"), "#settings.svg", SR.T("Настройка глобального порядка стадий сделок"), "toolbar-action-GlobalOrder", SR.T("Глобальный порядок")));
}

@Html.Action("Grid")