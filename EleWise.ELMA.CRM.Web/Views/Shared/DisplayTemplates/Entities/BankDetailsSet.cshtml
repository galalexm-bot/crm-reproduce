@using EleWise.ELMA.Web.Mvc.Views.Inputs
@using EleWise.ELMA.CRM.Models.BillingInformation
@using EleWise.ELMA.Model.Types.Settings
@inherits InputControl<IEnumerable<IBankDetails>, EntitySettings>

@if (Model != null)
{
    foreach (var item in Model)
    {
        if (item != null && !item.IsDeleted)
        {
            <div>
                @Html.Partial("DisplayTemplates/Entities/BankDetails", item)
            </div>
        }
    }
}