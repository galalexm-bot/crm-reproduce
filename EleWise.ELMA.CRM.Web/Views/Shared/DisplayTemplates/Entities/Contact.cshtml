@using EleWise.ELMA
@using EleWise.ELMA.Model.Entities
@model EleWise.ELMA.CRM.Models.IContact

@if (Model != null)
{
    if (Model.IsDeleted)
    {
        <span>[@SR.T("удален")]</span> @Model.GetTitleOrDefault(m => m.Name)
    }
    else if (Model.IsNew())
    {
        @Model.GetTitleOrDefault(m => m.Name)
    }
    else
    {
        <a href="@Url.Entity(Model)">@Model.GetTitleOrDefault(m => m.Name)</a>
    }
}