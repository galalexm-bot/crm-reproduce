@model RelationshipModel
@using EleWise.ELMA.CRM.Enums
@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.Web.Mvc.Models.Panels

@{
    var number = Model.Entity.RelationshipUsers.Count(eu => eu.Status == RelationshipUserStatus.InfromTo);
    if (number > 0)
    {
        <tr>
            <td colspan="2" style="border-bottom: none; padding: 0;">
                <div class="brickPanel">
                    @{
        var icon = "#complete.svg";
        var iconText = "";
                    }

                    @using (Html.CollapsiblePanel(new CollapsiblePanel
                    {
                        Id = "relationshipInformTo",
                        Expanded = true,
                        Header = EleWise.ELMA.SR.ToInfrom + " (" + number + ")",
                        Class = "brickTitle",
                        LoadMode = DynamicLoadMode.Client
                    }))
                    {
                        <table>
                            @foreach (var ev in Model.Entity.RelationshipUsers.Where(eu => eu.Status == RelationshipUserStatus.InfromTo))
                            {
                                <tr>
                                    <td style="width: 20px; white-space: nowrap">@(Html.Image(icon, iconText))</td>
                                    <td>@Html.HtmlHelperFunc(ev, helper => helper.Display(u => u.User))</td>
                                </tr>
                            }
                        </table>
                    }
                </div>
            </td>

        </tr>
    }
}
