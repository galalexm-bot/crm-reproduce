@model EleWise.ELMA.CRM.Models.IPhone

@if (Model != null && !Model.IsNew())
{
    @Html.HiddenFor(m => m.Id)
}
@Html.EditorFor(m => m.PhoneString, new { ViewAttributes = new WebViewAttributes() })
@Html.Hidden("", null, new { @class = "deleted validationMoveField", moveTo = ViewData.TemplateInfo.GetFullHtmlFieldId("PhoneString") })
<script type="text/javascript">
    $(document).ready(function () {
        elma.ValidationRulesManager.add('@ViewData.TemplateInfo.GetFullHtmlFieldId("")');
        elma.ValidationRulesManager.executeMove();
    });
</script>
