@model EleWise.ELMA.CRM.Web.Models.RelationshipMailModel
@using EleWise.ELMA
@using EleWise.ELMA.CRM.Managers
@using EleWise.ELMA.Extensions
@using EleWise.ELMA.Helpers
@using EleWise.ELMA.Model.Types.Settings
@using EleWise.ELMA.Security.Types.Settings
@using EleWise.ELMA.Web.Mvc
@using EleWise.ELMA.Web.Mvc.Html.Forms
@using ViewType = EleWise.ELMA.Model.Views.ViewType

@using (Html.DynamicForm("RelationshipMailDynamicForm", Guid.NewGuid()))
{    
    var viewType = Model.Entity.IsNew() ? ViewType.Create : ViewType.Edit;

    @Html.Partial("Relationship/RelationshipSubmitScript")

    if (!Model.Entity.IsNew())
    {
     @Html.HiddenFor(m => m.Entity.Id)
 }
    @Html.HiddenFor(m => m.Entity.TypeUid)
    @Html.HiddenFor(m => m.PrevContactId)
    @Html.HiddenFor(m => m.PrevContractorId)
    @Html.HiddenFor(m => m.PrevLeadId)
    @Html.HiddenFor(m => m.PrevSaleId)
 for (int i = 0; i < Model.PrevContractorContactsIds.Count; i++)
 {
     @Html.HiddenFor(m => m.PrevContractorContactsIds[i])
 }
 if (Model.Entity.Contractor != null && Model.LinkReadOnly)
 {
     @Html.HiddenFor(m => Model.Entity.Contractor.Id)
 }
 if (Model.Entity.Contact != null && Model.LinkReadOnly)
 {
     @Html.HiddenFor(m => Model.Entity.Contact.Id)
 }
 if (Model.Entity.Lead != null && Model.LinkReadOnly)
 {
     @Html.HiddenFor(m => Model.Entity.Lead.Id)
 }
 if (Model.Entity.Sale != null && Model.LinkReadOnly)
 {
     @Html.HiddenFor(m => Model.Entity.Sale.Id)
 }
 if (Model.Contacts != null)
 {
     for (int i = 0; i < Model.Contacts.Count; i++)
     {
         @Html.HiddenFor(m => m.Contacts[i].Id)
     }
 }
 if (Model.Contractors != null)
 {
     for (int i = 0; i < Model.Contractors.Count;
         i++)
     {
         @Html.HiddenFor(m => m.Contractors[i].Id)
     }
 }
 if (Model.Leads != null)
 {
     for (int i = 0; i < Model.Leads.Count; i++)
     {
         @Html.HiddenFor(m => m.Leads[i].Id)
     }
 }
 if (Model.Sales != null)
 {
     for (int i = 0; i < Model.Sales.Count; i++)
     {
         @Html.HiddenFor(m => m.Sales[i].Id)
     }
 }
    @Html.HiddenFor(m => m.IsMultiCreation)
    @Html.HiddenFor(m => m.LinkReadOnly)
    @Html.DynamicFormSettings(Model.DynamicFormSettings)

 if (DirectoryMapVirtualPathProvider.AnyConfigFile("~/Modules/EleWise.ELMA.CRM.Web/Views/Relationship/LinkedEntity.cshtml"))
 {
     @Html.TableFormStart(ViewType.Edit)
     <tr>
         <td class="captionCell">@Html.Caption(m => m.Entity.Theme)</td>
         <td>@Html.Editor(m => m.Entity.Theme)</td>
     </tr>
     <tr>
         <td class="captionCell">@Html.Caption(m => m.PartyUsers, a => a.Name = SR.Partisipants)</td>
         <td>
             @Html.Editor(m => m.PartyUsers, a =>
             {
                 a.Name = SR.Partisipants;
                 a.TypeSettingsAction = settingsAction =>
                 {
                     var userSettings = (EntityUserSettings)settingsAction;
                     userSettings.CheckReplacement = true;
                 };
             })
         </td>
     </tr>
     <tr>
         <td class="captionCell">@Html.Caption(m => m.InformUsers, a => a.Name = SR.ToInfrom)</td>
         <td>@Html.Editor(m => m.InformUsers, a => a.Name = SR.ToInfrom)</td>
     </tr>
     <tr>
         <td class="captionCell">@Html.Caption(m => m.Entity.StartDate, a => a.Name = SR.T("Дата отправки"))</td>
         <td>@Html.Editor(m => m.Entity.StartDate)</td>
     </tr>
     <tr>
         <td class="captionCell">@Html.Caption(m => m.Entity.Priority)</td>
         <td>@Html.Editor(m => m.Entity.Priority)</td>
     </tr>

     @Html.Partial("Relationship/LinkedEntity", Model)

     if (Model.IsMultiCreation)
     {
         <tr>
             <td class="captionCell">@Html.Caption(m => m.Interval)</td>
             <td>@Html.Editor(m => m.Interval, a => a.TypeSettings = new DateTimeSettings {ShowDate = false})</td>
         </tr>
     }

     <tr>
         <td class="captionCell">@Html.Caption(m => m.Entity.Description)</td>
         <td>@Html.Editor(m => m.Entity.Description)</td>
     </tr>

     var custompropCount = 0;
     var customView = Html.BuildFormForModel(Model.Entity, viewType,
         b =>
         {
             b.HideForm();
             b.Prefix("Entity");
             b.LayoutConfig<DefaultFormLayout>(l => l.RenderTable = false);
             b.ShowOnlyUserProperties();
             b.EachPropertyRow(r =>
             {
                 if (r.Visible) custompropCount++;
             });
         });
     if (custompropCount > 0)
     {
         @customView
     }
     @Html.TableFormEnd()
 }
 else
 {
     var viewItemId = !String.IsNullOrEmpty(Model.ViewItemId)
         ? Model.ViewItemId
         : Model.DynamicFormSettings != null
             ? Model.DynamicFormSettings.ViewItemId
             : null;
     @Html.FormViewItem(Model.View ?? Model.FormViewItem(Model.ViewType), m => m.Entity, null, Model.ViewType,
         Model.ItemType,
         EntityObjectViewItemProvider.UID, viewItemId,
         Model.DynamicFormSettings != null ? Model.DynamicFormSettings.DynamicFormsProviderUid : Guid.Empty,
         Model.DynamicFormSettings != null ? Model.DynamicFormSettings.DynamicFormsProviderData : null,
         Model.FormId)
 }

    @(Html.PopupWindow("CrossedEventsWindow", SR.T("Найдены пересечения"), @<text><div class="elma-window-content" style="min-width: 650px;"></div>></text>))
}