@inherits ViewItemControl<RelationshipParticipantsViewItem, RelationshipModel, IRelationship>
@using EleWise.ELMA.CRM.Models
@using EleWise.ELMA.CRM.ViewItems
@using EleWise.ELMA.CRM.Web.Models
@using EleWise.ELMA.Model.Views
@using EleWise.ELMA.Web.Mvc.Views.ViewItem
@using ViewType = EleWise.ELMA.Model.Views.ViewType

@if (ViewItem != null)
{
    Html.RemovePrefix("Entity");
    if (ViewItem.FormViewItem.IsReadOnly() || ViewItem.FormViewItem.ViewType == ViewType.Display)
    {
        @Html.Partial("DisplayTemplates/RelationshipParticipantsPanel", OriginalModel)
    }
    else
    {
        @Html.Partial("EditorTemplates/RelationshipParticipants", OriginalModel)
    }
    Html.AddPrefix("Entity");
}