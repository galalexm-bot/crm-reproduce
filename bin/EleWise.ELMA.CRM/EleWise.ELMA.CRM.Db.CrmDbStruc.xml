  <scripts>
    <script name="FixWrongSaleProductQuantity">
      <text>
        update SaleProduct set Quantity = 1 where Quantity &lt; 1 or Quantity is null
      </text>
    </script>
    
    <script name="FixWrongRelationshipDoneDate">
      <text>
        update Relationship set DoneDate = NULL where Completed IS NULL OR Completed = 0
      </text>
    </script>

    <script name="CountLeadsAndSales">
      <text>
        UPDATE MarketingBase SET
          DirtyLeadCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Lead&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp;),
          CleanLeadCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Lead&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0 AND Status&lt;&gt;4),
          AcceptedLeadCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Lead&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0 AND Status in (1,2,3)),
          QualifiedLeadCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Lead&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0 AND Status=2),
          CreatedSaleCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Sale&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0),
          PositiveSaleCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Sale&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0 AND SaleStatus = 3),
          NegativeSaleCount = (SELECT COUNT(&amp;&amp;Id&amp;&amp;) FROM &amp;&amp;Sale&amp;&amp; WHERE MarketingActivity=MarketingBase.&amp;&amp;Id&amp;&amp; AND IsDeleted=0 AND SaleStatus = 4),
          Status = 0,
          BudgetType = 0
      </text>
    </script>
    
