    <EmbeddedResource Include="EleWise.ELMA.Core.React.min.js" />
    <EmbeddedResource Include="Bridge.Resources.json" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Bridge" />
    <Reference Include="EleWise.ELMA.Core">
      <HintPath>..\..\Modules\EleWise.ELMA.Core.dll</HintPath>
    </Reference>
    <Reference Include="EleWise.ELMA.Core.Abstractions.Metadata" />
    <Reference Include="Bridge.React" />
    <Reference Include="EleWise.ELMA.Core.UI" />
    <Reference Include="Bridge.Html5" />
    <Reference Include="EleWise.ELMA.IoC" />
  </ItemGroup>
</Project>