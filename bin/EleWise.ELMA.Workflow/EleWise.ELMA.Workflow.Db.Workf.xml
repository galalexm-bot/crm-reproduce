    <procedure name="ResponsibilityProcessCheck">
      <mappings>
        <hibernate-mapping xmlns="urn:nhibernate-mapping-2.2">
          <resultset name="ResponsobilityMatrixHandler">
            <return-scalar column="BPMNProcess" type="System.Int64"/>
          </resultset>
          <sql-query name="ResponsibilityProcessCheck" resultset-ref="ResponsobilityMatrixHandler">
            <query-param name="userfilter" type="System.Int64" />
            <query-param name="orgitemtype" type="System.Guid" />
            <query-param name="usergrouptype" type="System.Guid" />
            <![CDATA[
            select &&BPMNProcess&& from &&ResponsibilityMatrixItem&& rm
            left join &&OrganizationItem&& dep on rm.&&WorkerType&& = :orgitemtype and dep.&&Id&& = rm.&&WorkerId&&
            left join &&OrganizationItemUsers&& du on rm.&&WorkerType&& = :orgitemtype and du.&&OrganizationItemId&& = dep.&&Id&&
            left join &&UserSecuritySetCache&& agu on rm.&&WorkerType&& = :usergrouptype and agu.&&GroupId&&=rm.&&WorkerId&&
            where rm.&&ResponsibilityLevel&& = 2 and 
	              (dep.&&UserId&& = :userfilter or 
	              (rm.&&WorkerType&& = :orgitemtype and du.&&UserId&& = :userfilter) or 
	              (rm.&&WorkerType&& = :usergrouptype and agu.&&UserId&& = :userfilter))
            ]]>
          </sql-query>
        </hibernate-mapping>
      </mappings>
      <text>
      </text>
    </procedure>


  </procedures>

